{
    "buildCommand": "cd Frontend/frontend && npm install && npm run build",
    "outputDirectory": "Frontend/frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/Backend/api/index.js"
        },
        {
            "source": "/((?!assets/).*)",
            "destination": "/index.html"
        }
    ]
}